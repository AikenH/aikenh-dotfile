#font-family = "Maple Mono NF CN"
font-family = "Inconsolata LGC Nerd Font Mono"
font-family = "TsangerJinKai03"
#font-family = "LXGW WenKai Mono"
font-feature = "+calt,+liga,+dlig"

# clipboard
clipboard-read=allow
clipboard-write=allow
copy-on-select=clipboard

theme = Fahrenheit
# theme = Dawnfox
# theme = Duckbones
# theme = dark:adventure,light:flexoki light
# theme = dark:cutie pro,light:novel
# background = 000000
background-opacity = 0.7
background-blur = 20
#background-blur = true
#background-blur-radius = 20

# windows
window-decoration = auto
window-save-state = always
macos-window-shadow = true
macos-titlebar-style = tabs

# logo
# macos-icon = paper
macos-icon-frame=chrome

# mouse
mouse-hide-while-typing = false

# cursor
custom-shader = shaders/cursor_warp.glsl
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor,ssh-terminfo,ssh-env,sudo
